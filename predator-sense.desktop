[Desktop Entry]
Name=Acer Predator Sense
StartupWMClass=AcerPredatorSense
Version=1.0
Type=Application
Terminal=false
Exec=sh -c "pkexec env DISPLAY=$DISPLAY XAUTHORITY=$XAUTHORITY sh -c 'cd <path_to_PredatorSense> && python3 main.py'"
Comment=Application to control fan speed for Acer Predator Series
GenericName=Application to control fan speed, overlock, keyboard modes and colors
Icon=<path_to_PredatorSense>/data/PredatorLogo.png
